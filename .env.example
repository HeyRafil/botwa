# Environment Configuration for BotWAUT
NODE_ENV=development
PORT=3000

# WhatsApp Bot Settings
# Owner number must include country code without '+' sign (e.g. 628123456789)
OWNER_NUMBER=62895360042021
COOLDOWN_MS=3000

# OpenAI API Settings
# Leave blank to run bot in offline semantic matching mode (no AI response generation)
OPENAI_API_KEY=your_openai_api_key_here

# Crawler & Scheduler Settings
# Crawl interval in hours (default is 6 hours)
CRAWLER_INTERVAL_HOURS=6
# Delay between request requests (in ms) to prevent rate limits on UT websites
CRAWLER_DELAY_MS=2000

# Path Settings (Relative to project root or Absolute path)
SESSION_PATH=./session
DATABASE_DIR=./storage/db
KNOWLEDGE_DIR=./storage/knowledge

# Web Dashboard Security
# Password to access the web panel to view status and scan QR code
WEB_DASHBOARD_PASSWORD=AdminUT2026
